{
  "project": {
    "name": {
      "title": "Branded Short Links",
      "slug": "branded-short-links"
    },
    "description": {
      "short": "Custom-domain URL shortener with direct server-side analytics tracking",
      "long": "Branded short links with server-side tracker integration (GA4 Measurement Protocol, Meta Pixel, PostHog, ntfy, Reverse Proxy for ntfy, plain-text webhooks), powered by Cloudflare Workers. Interactive CLI for configuration, validation, and deployment."
    },
    "keywords": [
      "url-shortener",
      "branded-links",
      "cloudflare-workers",
      "analytics",
      "ga4",
      "facebook",
      "posthog",
      "ntfy"
    ],
    "legalName": "CBN Ventures LLC",
    "pronouns": "business",
    "platforms": [
      "nodejs"
    ],
    "startingYear": 2024,
    "license": "MIT"
  },
  "entities": [
    {
      "name": "CBN Ventures",
      "email": "contact@cbnventures.io",
      "url": "https://www.cbnventures.io/",
      "roles": [
        "author"
      ]
    },
    {
      "name": "Jacky Liang",
