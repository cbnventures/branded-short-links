  "workflows": [
    {
      "template": "check-sponsor-gated-issues",
      "suffix": "project",
      "triggers": [
        "issue-comment",
        "issues"
      ],
      "settings": {
        "IS_ORGANIZATION": "IS_ORGANIZATION",
        "ISSUE_LABELS": "ISSUE_LABELS",
        "ISSUE_LIMIT_COMMENTER": "ISSUE_LIMIT_COMMENTER",
        "ISSUE_LOCK_ON_CLOSE": "ISSUE_LOCK_ON_CLOSE",
