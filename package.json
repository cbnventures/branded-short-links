{
  "name": "branded-short-links-project",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build --concurrency=2",
    "check": "turbo run check --concurrency=2",
    "deploy": "turbo run deploy --concurrency=2",
    "clean": "turbo run clean",
    "manage": "npm run manage --workspace packages/branded-short-links",
    "tail": "node ./scripts/tail-logs.mjs",
    "changelog": "nova utility changelog",
    "recipes": "nova utility run-recipes --replace-file",
    "postinstall": "node ./scripts/link-nova.mjs"
  },
  "workspaces": [
    "./apps/*",
    "./packages/*"
  ],
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "devDependencies": {
    "@cbnventures/nova": "0.15.3",
    "jiti": "2.6.1",
    "prompts": "2.4.2",
    "turbo": "2.8.12"
  },
  "overrides": {
    "webpack": ">=5.95.0 <5.106.0"
  }
}
