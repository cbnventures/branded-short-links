{
  "name": "branded-short-links-docs",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "nova utility run-scripts --parallel 'dev:*'",
    "dev:start": "PORTLESS_PORT=3000 portless dev-bsl-docs docusaurus start --host 0.0.0.0 --no-open",
    "prod": "nova utility run-scripts --sequential 'prod:*'",
    "prod:serve": "PORTLESS_PORT=3000 portless prod-bsl-docs docusaurus serve --host 0.0.0.0 --no-open",
    "build": "nova utility run-scripts --sequential 'build:*'",
    "build:build": "docusaurus build",
    "build:transpile-app": "nova utility transpile --project tsconfig.app.json",
    "build:fix-markdown-tables": "node ../../scripts/fix-markdown-tables.mjs",
    "check": "nova utility run-scripts --sequential 'check:*'",
    "check:lint": "eslint ./ --max-warnings=0",
    "check:types-app": "nova utility type-check --project tsconfig.app.json",
    "check:types-tests": "nova utility type-check --project tsconfig.tests.json",
    "check:test": "vitest run",
    "clean": "nova utility run-scripts --parallel 'clean:*'",
    "clean:build": "shx rm -rf ./build",
    "clean:clear": "docusaurus clear"
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "dependencies": {
    "@cbnventures/docusaurus-preset-nova": "0.17.0",
    "@cbnventures/nova": "0.17.0",
    "@docusaurus/core": "3.10.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@types/node": "24.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "portless": "0.10.1",
    "eslint": "9.39.3",
    "glob": "13.0.6",
    "shx": "0.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.3"
  }
}
